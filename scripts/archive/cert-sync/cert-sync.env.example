SOURCE_HOST=my-muffin.top
SOURCE_PORT=22
SOURCE_USER=root
SOURCE_CERT_DIR=/root/testPemDir
SOURCE_FULLCHAIN_PATH=/root/testPemDir/fullchain.pem
SOURCE_PRIVKEY_PATH=/root/testPemDir/privkey.pem
SOURCE_SSH_PASSWORD='replace-with-source-root-password'

LOCAL_CERT_DIR=/root/testPemDir
LOCAL_FULLCHAIN_PATH=/root/testPemDir/fullchain.pem
LOCAL_PRIVKEY_PATH=/root/testPemDir/privkey.pem

KNOWN_HOSTS_FILE=/root/.ssh/known_hosts
MIN_DAYS_LEFT=15
AUTO_INSTALL_SSHPASS=1
FORCE_SYNC=0
SERVICE_RELOAD_CMD='nginx -t && systemctl reload nginx'

LOG_DIR=/var/log/kodexlink
LOG_FILE=/var/log/kodexlink/cert-sync.log
LOCK_FILE=/var/run/kodexlink-cert-sync.lock

{
  "name": "@kodexlink/relay-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "migrate": "pnpm build && node dist/server.js migrate",
    "start": "pnpm build && node dist/server.js serve",
    "threads": "pnpm build && node dist/server.js threads",
    "resume": "pnpm build && node dist/server.js resume",
    "chat": "pnpm build && node dist/server.js chat"
  },
  "dependencies": {
    "@kodexlink/protocol": "workspace:*",
    "@kodexlink/schemas": "workspace:*",
    "@kodexlink/shared": "workspace:*",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "ws": "^8.18.3"
  }
}
